{
  "uid": "sre-container-logs",
  "title": "Container Logs",
  "description": "Container log aggregation via Loki and Promtail",
  "tags": [
    "sre",
    "logs",
    "loki",
    "promtail"
  ],
  "style": "dark",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "graphTooltip": 1,
  "annotations": {
    "list": []
  },
  "templating": {
    "list": [
      {
        "name": "container",
        "label": "Container",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki-ds"
        },
        "query": "label_values(container)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Log volume by container",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-ds"
      },
      "targets": [
        {
          "expr": "sum by (container) (rate({container=~\"$container\"} [2m]))",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "logs/s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 2,
      "title": "All container logs",
      "type": "logs",
      "gridPos": {
        "h": 16,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-ds"
      },
      "targets": [
        {
          "expr": "{container=~\"$container\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    },
    {
      "id": 3,
      "title": "Error & fatal logs",
      "type": "logs",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-ds"
      },
      "targets": [
        {
          "expr": "{container=~\"$container\"} | logfmt | level=~\"(error|ERROR|Error|fatal|FATAL|critical|CRITICAL)\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    }
  ]
}